# Bloquea acceso directo a la raíz de la API.
# SOLO api/public/ debe ser accesible por el navegador; src/ y config/
# quedan protegidos. En producción se recomienda apuntar el document root
# del subdominio directamente a api/public/ (ver docs/DEPLOY.md).
Require all denied

# Fallback para Apache < 2.4
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
