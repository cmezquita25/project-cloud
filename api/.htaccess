# ==========================================================================
#  Project Cloud — API
#  Toda petición /api/* se enruta al front controller (api/index.php) desde el
#  .htaccess RAÍZ. Aquí NO denegamos el acceso (eso causaba 403 en Plesk):
#  la protección de src/ y config/ se hace con sus propios .htaccess (hojas) y
#  porque todo /api/* pasa por index.php.
# ==========================================================================

Options -Indexes

# Si se accediera directamente a una carpeta, redirigir al front controller.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /api/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L]
</IfModule>
