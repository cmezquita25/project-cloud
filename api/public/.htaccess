# Re-permite el acceso a public/ (la carpeta api/ padre tiene "Require all denied"
# para proteger src/ y config/; aquí lo revertimos SOLO para el front controller).
Require all granted
<IfModule !mod_authz_core.c>
    Order allow,deny
    Allow from all
</IfModule>

# Reescribe todas las peticiones al front controller.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /api/public/

    # Si el archivo o directorio existe físicamente, servirlo tal cual.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Todo lo demás va a index.php.
    RewriteRule ^ index.php [L]
</IfModule>

# Sin listado de directorios.
Options -Indexes
